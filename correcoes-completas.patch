diff -ruN source_before_final/supabase/auditoria-somente-leitura.sql source/supabase/auditoria-somente-leitura.sql
--- source_before_final/supabase/auditoria-somente-leitura.sql	1970-01-01 00:00:00.000000000 +0000
+++ source/supabase/auditoria-somente-leitura.sql	2026-06-24 06:26:42.876545449 +0000
@@ -0,0 +1,94 @@
+-- AUDITORIA SOMENTE LEITURA — TEM NO ENTORNO SUL
+-- Não altera dados, tabelas, funções ou policies.
+
+-- 1. Tabelas, estimativa de linhas e RLS
+select
+    n.nspname as esquema,
+    c.relname as tabela,
+    c.reltuples::bigint as linhas_estimadas,
+    c.relrowsecurity as rls_ativo
+from pg_class c
+join pg_namespace n on n.oid = c.relnamespace
+where n.nspname = 'public'
+  and c.relkind in ('r', 'p')
+order by c.relname;
+
+-- 2. Colunas e tipos
+select table_name, ordinal_position, column_name, data_type, udt_name,
+       is_nullable, column_default
+from information_schema.columns
+where table_schema = 'public'
+order by table_name, ordinal_position;
+
+-- 3. Chaves primárias, únicas e estrangeiras
+select tc.table_name, tc.constraint_name, tc.constraint_type,
+       kcu.column_name, ccu.table_name as tabela_referenciada,
+       ccu.column_name as coluna_referenciada
+from information_schema.table_constraints tc
+left join information_schema.key_column_usage kcu
+  on tc.constraint_name = kcu.constraint_name
+ and tc.constraint_schema = kcu.constraint_schema
+left join information_schema.constraint_column_usage ccu
+  on tc.constraint_name = ccu.constraint_name
+ and tc.constraint_schema = ccu.constraint_schema
+where tc.table_schema = 'public'
+order by tc.table_name, tc.constraint_type, tc.constraint_name, kcu.ordinal_position;
+
+-- 4. Policies RLS
+select schemaname, tablename, policyname, permissive, roles, cmd, qual, with_check
+from pg_policies
+where schemaname = 'public'
+order by tablename, policyname;
+
+-- 5. Funções públicas e configuração de segurança
+select n.nspname as esquema, p.proname as funcao,
+       pg_get_function_identity_arguments(p.oid) as argumentos,
+       p.prosecdef as security_definer, p.proconfig as configuracoes,
+       pg_get_function_result(p.oid) as retorno
+from pg_proc p
+join pg_namespace n on n.oid = p.pronamespace
+where n.nspname = 'public'
+order by p.proname, argumentos;
+
+-- 6. Views
+select schemaname, viewname, definition
+from pg_views
+where schemaname = 'public'
+order by viewname;
+
+-- 7. Triggers
+select event_object_table as tabela, trigger_name, action_timing,
+       event_manipulation, action_statement
+from information_schema.triggers
+where trigger_schema = 'public'
+order by event_object_table, trigger_name;
+
+-- 8. Índices
+select schemaname, tablename, indexname, indexdef
+from pg_indexes
+where schemaname = 'public'
+order by tablename, indexname;
+
+-- 9. Roles oficiais
+select * from public.roles order by id;
+
+-- 10. Usuários e roles
+select ur.id, ur.usuario_id, ur.role_id, r.nome as role_nome, ur.created_at
+from public.usuarios_roles ur
+left join public.roles r on r.id = ur.role_id
+order by ur.usuario_id, ur.role_id;
+
+-- 11. Possíveis e-mails duplicados
+select lower(trim(email)) as email_normalizado, count(*) as total
+from public.usuarios
+where email is not null and trim(email) <> ''
+group by lower(trim(email))
+having count(*) > 1
+order by total desc, email_normalizado;
+
+-- 12. Usuários sem role
+select u.id, u.nome, u.email, u.status, u.created_at
+from public.usuarios u
+left join public.usuarios_roles ur on ur.usuario_id = u.id
+where ur.usuario_id is null
+order by u.created_at;
